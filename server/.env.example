# ── ML model ──────────────────────────────────────────────────────────────────
# Sentence-transformer model used to embed documents and queries.
# Must match the model that was used when running generate_embeddings.py.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Paths ─────────────────────────────────────────────────────────────────────
# Directory containing the corpus zip (articles_corpus.zip).
DATA_DIR=data

# Directory where pipeline artifacts are read from at server startup:
# index.faiss, embeddings.npy, metadata.json, tags.json.
# On Railway: set this to the path of your mounted volume (e.g. /data/models).
MODELS_DIR=models

# ── Search ────────────────────────────────────────────────────────────────────
# Number of results returned by POST /search when top_k is not provided by the caller.
DEFAULT_TOP_K=5

# ── Clustering ────────────────────────────────────────────────────────────────
# Number of k-means topic clusters.
# Rerun cluster_documents.py after changing this value.
N_CLUSTERS=8

# ── Rate limits ───────────────────────────────────────────────────────────────
# Per-client request limits. Search is lower because it runs query embedding.
SEARCH_RATE_LIMIT_PER_MINUTE=30
TAGS_RATE_LIMIT_PER_MINUTE=120
